{
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "vite --open /index.react.html",
    "dev:react": "vite --open /index.react.html",
    "build": "vite build",
    "build:local": "powershell -ExecutionPolicy Bypass -File ./scripts/build-local.ps1",
    "build:rider:local": "powershell -ExecutionPolicy Bypass -File ./scripts/build-rider-local.ps1",
    "check:encoding": "node ./scripts/check-encoding.js",
    "check:deploy": "node ./scripts/check-deploy-smoke.js",
    "check:e2e": "node ./scripts/check-home-clicks.js",
    "check:native": "node ./scripts/check-native.js",
    "check:order-flow": "node ./scripts/check-order-flow.js",
    "check:pwa": "node ./scripts/check-pwa.js",
    "check:preflight": "corepack pnpm run build && corepack pnpm run check:deploy && corepack pnpm run check:e2e && corepack pnpm run check:roles && corepack pnpm run check:order-flow && corepack pnpm run check:rider-mode && corepack pnpm run check:native",
    "check:release-bundles": "powershell -ExecutionPolicy Bypass -File ./scripts/check-android-release-bundles.ps1",
    "check:rider-mode": "node ./scripts/check-rider-mode.js",
    "check:roles": "node ./scripts/check-role-visibility.js",
    "cap:sync": "pnpm run build:local && cap sync",
    "cap:android": "pnpm run cap:sync && cap open android",
    "cap:ios": "pnpm run cap:sync && cap open ios",
    "android:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-debug.ps1",
    "android:rider:debug": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-rider-debug.ps1",
    "android:bundle": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-release-bundle.ps1",
    "android:rider:bundle": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-rider-release-bundle.ps1",
    "dev:local": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-local.ps1",
    "preview": "vite preview"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@supabase/supabase-js": "^2.108.2",
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "three": "^0.184.0",
    "vite": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}
